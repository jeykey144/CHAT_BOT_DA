# Generic example. For local development, prefer copying .env.local.example to .env.
# For TOSE deployment, prefer .env.tose.example or TOSE dashboard secrets.

# --- App / session
COOKIE_SECRET=change-me
APP_LOG_LEVEL=INFO

# --- LLM Provider (groq, openai, google, anthropic)
LLM_PROVIDER=groq
LLM_TEMPERATURE=0.0

# 1. Groq (Default)
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# 2. Google Gemini
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GOOGLE_MODEL=gemini-1.5-pro

# 3. OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4000

# 4. Anthropic
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Code execution backend
# local  = run code locally with restricted imports (fast, MVP)
# e2b    = run code in E2B secure sandbox (recommended for production)
EXECUTOR_BACKEND=local

# --- Optional: E2B sandbox
# Required if EXECUTOR_BACKEND=e2b
E2B_API_KEY=YOUR_E2B_API_KEY
E2B_TEMPLATE=code-interpreter
E2B_TIMEOUT_S=60

# --- Auth DB
# Required by app.py. This default is for local MySQL.
APP_ENV=development
AUTH_DB_URL=mysql+pymysql://root:local_password@127.0.0.1:3306/chatbot?charset=utf8mb4
DB_CONNECT_TIMEOUT_S=10
DB_POOL_TIMEOUT_S=10
