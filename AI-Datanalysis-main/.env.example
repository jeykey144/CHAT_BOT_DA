# Rename this file to .env and fill your keys

# --- App / session
COOKIE_SECRET=change-me
APP_LOG_LEVEL=INFO

# --- LLM Provider (groq, openai, google, anthropic)
LLM_PROVIDER=groq
LLM_TEMPERATURE=0.0

# 1. Groq (Default)
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# 2. Google Gemini
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GOOGLE_MODEL=gemini-1.5-pro

# 3. OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4000

# 4. Anthropic
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Code execution backend
# local  = run code locally with restricted imports (fast, MVP)
# e2b    = run code in E2B secure sandbox (recommended for production)
EXECUTOR_BACKEND=local

# --- Optional: E2B sandbox
# Required if EXECUTOR_BACKEND=e2b
E2B_API_KEY=YOUR_E2B_API_KEY
E2B_TEMPLATE=code-interpreter
E2B_TIMEOUT_S=60

# --- Auth DB
# Required by app.py. Example with AWS RDS MySQL:
# AUTH_DB_URL=mysql+pymysql://root:<password>@mysql-chatbot.c3igik0cizol.ap-southeast-1.rds.amazonaws.com:3306/<database_name>?charset=utf8mb4
AUTH_DB_URL=mysql+pymysql://root:password@mysql-chatbot.c3igik0cizol.ap-southeast-1.rds.amazonaws.com:3306/chatbot?charset=utf8mb4
