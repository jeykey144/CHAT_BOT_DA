# Copy this file to .env for local development.
# Do not use this file for TOSE deployment.

APP_ENV=development
APP_LOG_LEVEL=INFO

LLM_PROVIDER=groq
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0

COOKIE_SECRET=local-dev-cookie-secret

# Local MySQL, for example from:
# docker run --name chatbot-mysql -e MYSQL_ROOT_PASSWORD=local_password -e MYSQL_DATABASE=chatbot -p 3306:3306 -d mysql:8
AUTH_DB_URL=mysql+pymysql://root:local_password@127.0.0.1:3306/chatbot?charset=utf8mb4
DB_CONNECT_TIMEOUT_S=10
DB_POOL_TIMEOUT_S=10

# Local executor is fine for development. Use e2b for production if available.
EXECUTOR_BACKEND=local
