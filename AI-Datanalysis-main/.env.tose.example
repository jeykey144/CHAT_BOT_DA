# Copy this file to .env.tose or set these values in the TOSE dashboard.
# Do not commit the real .env.tose file.

APP_ENV=production
APP_LOG_LEVEL=INFO

LLM_PROVIDER=groq
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0

COOKIE_SECRET=replace-with-long-random-secret

# Use a dedicated app DB user instead of root when possible.
AUTH_DB_URL=mysql+pymysql://ai_app:URL_ENCODED_PASSWORD@mysql-chatbot.c3igik0cizol.ap-southeast-1.rds.amazonaws.com:3306/chatbot?charset=utf8mb4
DB_CONNECT_TIMEOUT_S=10
DB_POOL_TIMEOUT_S=10

# Recommended for production if configured; otherwise leave local only if you accept the risk.
EXECUTOR_BACKEND=local
